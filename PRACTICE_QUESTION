bool isPrime(int n){
    if(n<=1) return false;
    
   for(int i = 2;i<= sqrt(n);i++){
       if(n%i==0)
           return false;
    }
      
           return true;
}

bool isExpressed(int n){
    for(int i=2;i<=n/2;i++){
        if(isPrime(i) && isPrime(n-i))
        return true;
    }
    return false;
}


int main(){
    
int n;
cin>>n;

cout<<(isExpressed(n) ? "true" :"false" );
return 0;

