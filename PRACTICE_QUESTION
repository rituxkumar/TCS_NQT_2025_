4. shift 0 at the end of array without disturbing order;


#include <bits/stdc++.h>
using namespace std;

int main() {
int n;
cin>>n;

vector<int>arr(n);
for(int i=0;i<n;i++){
    cin>>arr[i];
    
}

vector<int>result(n,0);

int index =0;
for(int i =0;i<n;i++){
    if(arr[i]>0){
        result[index++] = arr[i]; 
    }
}
for(auto it:result){
    cout<<it<<" ";
}

return 0;
 
}

