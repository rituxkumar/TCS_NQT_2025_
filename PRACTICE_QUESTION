    return true;

}

int Digit(int num) {
    while (num >= 10) {
        int sum = 0;
        while (num > 0) {
            sum += num % 10;
            num = num / 10;
        }
        num = sum;
    }
    return num;
}


int main() {

    int m;
    cin >> m;
    int num = 2;
    int count = 0;
