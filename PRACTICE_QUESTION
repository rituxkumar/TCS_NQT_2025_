#include <bits/stdc++.h>
using namespace std;

int main() {
int n;
cin>>n;

vector<int>arr(n);
for(int i=0;i<n;i++){
    cin>>arr[i];
}

for(int j=0;j<n;j++){
    int leftSum =0;
    int rightSum =0;
    
    for(int k=j-1;k>=0;k--){
        leftSum += arr[k];
      
    }
    
     
    for(int k=j+1;k<n;k++){
        rightSum  += arr[k];
      
    }
    
    if(leftSum == rightSum){
       cout<<j;
      return 0;
       
       
    }
         
}


cout<<-1;
}
