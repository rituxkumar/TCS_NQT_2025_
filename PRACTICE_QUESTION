#include <bits/stdc++.h>
using namespace std;

int main() {
	  int n ;
	  cin>>n;
	  int maxi =0;
	  
	  for(int i=1;i<=n;i++ ){
	     int leftOver = n%i ;
	     maxi = max(leftOver,maxi);
	  }
	  
	  cout<<maxi;

}



