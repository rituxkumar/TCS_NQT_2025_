using namespace std;

int main() {
    int n;
    cin >> n;

    vector < int > vec(n);
    for (int i = 0; i < n; i++) {
        cin >> vec[i];
    }

    unordered_map < int, int > mp;
    unordered_map < int, int > index;

    //  frequncy + first index;


    for (int i = 0; i < n; i++) {
        mp[vec[i]]++;

        if (index.find(vec[i]) == index.end()) {
            index[vec[i]] = i;
        }
    }

    // custom sort;

    vector < int > temp = vec;

    sort(temp.begin(), temp.end(), [ & ](int a, int b) {
        if (mp[a] != mp[b]) {
            return mp[a] < mp[b];
        } else {
            return index[a] < index[b];
        }

    });


    // print 

    for (auto it: temp) {
        cout << it << " ";
    }

    int key;
    cin >> key;

    for (int i = 0; i < n; i++) {
        if (key == vec[i]) {
            cout << i;
            return 0;
            
        }
    }
    cout << -1;
    
 

}

